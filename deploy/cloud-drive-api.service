[Unit]
Description=Cloud Drive Pre-signed URL API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/cloud-drive
ExecStart=/home/ubuntu/cloud-drive/venv/bin/python /home/ubuntu/cloud-drive/api.py
Restart=on-failure
RestartSec=5
Environment=AWS_DEFAULT_REGION=us-east-1
Environment=CLOUD_DRIVE_PASSWORD=vryKly0IEbkf1xZFiLu8

[Install]
WantedBy=multi-user.target
